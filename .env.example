APP_NAME="Automated Outreach Pipeline"
ENVIRONMENT=local
DEBUG=false
APP_API_KEY=

LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log

DATABASE_URL=postgresql+psycopg://outreach:outreach@postgres:5432/outreach
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false

HTTP_TIMEOUT_SECONDS=20
RETRY_MAX_RETRIES=3
RETRY_BACKOFF_BASE_SECONDS=1
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60
CACHE_TTL_SECONDS=3600

OCEAN_BASE_URL=https://api.ocean.io/v3
OCEAN_API_KEY=
OCEAN_COMPANY_LIMIT=20

PROSPEO_BASE_URL=https://api.prospeo.io
PROSPEO_API_KEY=
PROSPEO_PAGE_LIMIT=1

EAZYREACH_BASE_URL=https://api.eazyreach.app
EAZYREACH_API_KEY=
EAZYREACH_EMAIL_LOOKUP_PATH=/api/v1/linkedin/email

BREVO_BASE_URL=https://api.brevo.com/v3
BREVO_API_KEY=
BREVO_SENDER_EMAIL=outreach@example.com
BREVO_SENDER_NAME=Vocallabs
BREVO_REPLY_TO_EMAIL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OUTREACH_PRODUCT_NAME=Vocallabs
OUTREACH_VALUE_PROP="AI-powered voice and outreach automation that helps revenue teams qualify prospects faster and follow up consistently"
OUTREACH_CALL_TO_ACTION="Would it be worth a short conversation next week?"

